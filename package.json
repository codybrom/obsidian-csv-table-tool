{
	"name": "csv-table-tool",
	"version": "0.2.0",
	"description": "Open CSV files as native tables in Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "npm run typecheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "npm run typecheck && npm run lint && npm run format:check",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"obsidian-md",
		"csv",
		"table",
		"spreadsheet",
		"tabletool"
	],
	"author": "Cody Bromley",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.6.1",
		"esbuild": "^0.28.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"obsidian": "^1.12.3",
		"prettier": "^3.8.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2"
	}
}
